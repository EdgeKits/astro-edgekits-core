---
import { Newsletter } from '@/components/blog/islands/Newsletter'
import { fetchTranslations } from '@/domain/i18n/fetcher'

const { translationLocale, runtime } = Astro.locals

const { newsletter } = await fetchTranslations(runtime, translationLocale, [
  'newsletter',
])
---

<Newsletter
  client:visible
  t={newsletter}
/>
