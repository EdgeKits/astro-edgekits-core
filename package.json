{
  "name": "astro-edgekits-core",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/EdgeKits/astro-edgekits-core.git"
  },
  "type": "module",
  "private": true,
  "version": "2.0.0",
  "cloudflare": {
    "bindings": {
      "TRANSLATIONS": {
        "description": "A KV namespace to store translations."
      }
    },
    "vars": {
      "I18N_CACHE": {
        "description": "on/off"
      },
      "DEBUG_I18N": {
        "description": "on/off"
      },
      "DEMO_MODE": {
        "description": "on/off"
      },
      "CLOUDFLARE_ZONE_ID": {
        "description": "your cloudflare zone id string"
      }
    }
  },
  "scripts": {
    "astro": "astro",
    "setup": "node scripts/setup.mjs",
    "dev": "wrangler types && astro dev",
    "build": "wrangler types && astro build",
    "preview": "astro build && wrangler dev",
    "deploy": "astro build && wrangler deploy",
    "typegen": "wrangler types",
    "i18n:bundle": "tsx scripts/bundle-translations.ts",
    "i18n:seed": "tsx scripts/bundle-translations.ts --fallbacks --deploy-version --local",
    "i18n:migrate": "tsx scripts/bundle-translations.ts --fallbacks --deploy-version"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^12.6.13",
    "@astrojs/mdx": "^4.3.14",
    "@astrojs/react": "^4.4.2",
    "@astrojs/rss": "^4.0.18",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@fontsource-variable/noto-sans-jp": "^5.2.9",
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "astro": "^5.18.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.554.0",
    "react-hook-form": "^7.72.1",
    "tailwind-merge": "^3.4.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.8",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "jsonc-parser": "^3.3.1",
    "miniflare": "^4.20260401.0",
    "prettier": "^3.8.1",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "wrangler": "^4.82.2"
  }
}
